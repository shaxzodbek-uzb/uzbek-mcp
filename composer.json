{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "shaxzodbek-uzb/uzbek-mcp",
    "type": "project",
    "description": "The Uzbek language MCP server: transliteration (Latin ↔ Cyrillic), number-to-words, text normalization, slugify, plus live Uzbekistan data (CBU currency rates, public holidays, weather). Built on Laravel MCP.",
    "keywords": [
        "mcp",
        "model-context-protocol",
        "uzbek",
        "uzbekistan",
        "transliteration",
        "latin-cyrillic",
        "laravel",
        "laravel-mcp",
        "ai",
        "claude"
    ],
    "homepage": "https://github.com/shaxzodbek-uzb/uzbek-mcp",
    "license": "MIT",
    "authors": [
        {
            "name": "Shaxzodbek Qambaraliyev",
            "email": "shaxzodbek@blaze.uz"
        }
    ],
    "support": {
        "issues": "https://github.com/shaxzodbek-uzb/uzbek-mcp/issues",
        "source": "https://github.com/shaxzodbek-uzb/uzbek-mcp"
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^13.8",
        "laravel/mcp": "^0.8.1",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate --ansi"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "lint": [
            "pint"
        ],
        "inspect": [
            "@php artisan mcp:inspector uzbek"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
